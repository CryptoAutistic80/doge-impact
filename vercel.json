{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/methodology",
      "destination": "/methodology/index.html"
    },
    {
      "source": "/sources",
      "destination": "/sources/index.html"
    },
    {
      "source": "/support-us",
      "destination": "/support-us/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
